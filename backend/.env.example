# Safe WA Gateway — Environment Config
# Copy file ini ke .env dan isi dengan nilai asli

# ── Evolution API ──────────────────────────────────────────────────────────────
EVO_URL=http://localhost:8080
EVO_INSTANCE=wagateway1
EVO_APIKEY=YOUR_EVOLUTION_API_KEY

# ── Google Gemini (untuk Warm-Up Bot) ─────────────────────────────────────────
# Dapatkan gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Redis (untuk upgrade dari AsyncIO ke Celery) ───────────────────────────────
# Windows: install Memurai (https://www.memurai.com/) lalu jalankan memurai
# Cloud gratis: https://upstash.com/
REDIS_URL=redis://localhost:6379/0

# ── App Config ─────────────────────────────────────────────────────────────────
APP_ENV=development
RATE_LIMIT_PER_MIN=3
MAX_RETRIES=3

# ── Frontend URL (untuk CORS) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
